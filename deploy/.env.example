# Production installs use prebuilt images and Docker Compose.
# Copy this file to .env, then change every "change-me" value before starting.
APP_ENV=production

# Image coordinates. Use an immutable release tag in production, for example v1.0.0.
LITEWAF_IMAGE_PREFIX=litewaf
LITEWAF_IMAGE_TAG=latest

POSTGRES_DB=litewaf
POSTGRES_USER=litewaf
POSTGRES_PASSWORD=change-me
PUBLISH_OPERATOR=compose
AUTH_TOKEN_SECRET=change-me
GATEWAY_INGESTION_TOKEN=change-me

# Metrics default to disabled. If enabled, expose metrics only on trusted networks.
METRICS_ENABLED=false
LITEWAF_METRICS_ENABLED=false

LITEWAF_SENSITIVE_HEADERS=authorization,cookie,set-cookie
LITEWAF_LOG_VALUE_MAX_LEN=160

# Gateway shared dict sizes are configured in the gateway image nginx.conf.
# Increase litewaf_rate_limit/litewaf_dynamic_ban there for high-cardinality traffic.
LITEWAF_ADMIN_USERNAME=admin
LITEWAF_ADMIN_PASSWORD=change-me
LITEWAF_ADMIN_ROLE=admin

# Do not expose the management dashboard directly to the public internet.
# Use VPN, bastion access, reverse proxy authentication, or IP allowlists.
DASHBOARD_PORT=18080
GATEWAY_PORT=18081
