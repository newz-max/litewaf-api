# Production installs use prebuilt images and Docker Compose.
# Copy this file to .env, then change every "change-me" value before starting.
APP_ENV=production

# Image coordinates. Use an immutable release tag in production, for example v1.0.0.
LITEWAF_IMAGE_PREFIX=litewaf
LITEWAF_IMAGE_TAG=latest

POSTGRES_DB=litewaf
POSTGRES_USER=litewaf
POSTGRES_PASSWORD=change-me
PUBLISH_OPERATOR=compose
AUTH_TOKEN_SECRET=change-me
GATEWAY_INGESTION_TOKEN=change-me

# Protected application listeners.
# Default production mode is host-network: Gateway binds published application ports
# such as 80/http, 443/https, and custom listeners directly on the Linux host.
GATEWAY_LISTENER_MODE=host-network
GATEWAY_BRIDGE_PORT_RANGE=

# Optional API-triggered Gateway reload command. litewafctl.sh fills this for
# local production installs; leave empty only if reload is coordinated externally.
GATEWAY_RELOAD_COMMAND=

# Host-network Gateway cannot use Compose DNS. API is published only on loopback
# so Gateway can ingest logs without exposing the management API publicly.
API_LOOPBACK_ADDR=127.0.0.1
API_LOOPBACK_PORT=18081
LITEWAF_INGESTION_URL=http://127.0.0.1:18081

# Metrics default to disabled. If enabled, expose metrics only on trusted networks.
METRICS_ENABLED=false
LITEWAF_METRICS_ENABLED=false

LITEWAF_SENSITIVE_HEADERS=authorization,cookie,set-cookie
LITEWAF_LOG_VALUE_MAX_LEN=160

# Optional GeoIP CSV database. Run "./litewafctl.sh geoip update" to download
# DB-IP Lite Country data into ./data/geoip and enable this path automatically.
LITEWAF_GEOIP_DB_PATH=
LITEWAF_GEOIP_CACHE_SIZE=2048

# Real client IP recovery for deployments behind Docker bridges, load balancers, CDNs, or reverse proxies.
# Leave LITEWAF_REAL_IP_TRUSTED_CIDRS empty unless the immediate peer is a trusted proxy.
LITEWAF_REAL_IP_TRUSTED_CIDRS=
LITEWAF_REAL_IP_HEADER=X-Forwarded-For
LITEWAF_REAL_IP_RECURSIVE=on

# Gateway shared dict sizes are configured in the gateway image nginx.conf.
# Increase litewaf_rate_limit/litewaf_dynamic_ban there for high-cardinality traffic.
LITEWAF_ADMIN_USERNAME=admin
LITEWAF_ADMIN_PASSWORD=change-me
LITEWAF_ADMIN_ROLE=admin

# Do not expose the management dashboard directly to the public internet.
# Use VPN, bastion access, reverse proxy authentication, or IP allowlists.
DASHBOARD_PORT=18080
